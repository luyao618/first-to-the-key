{
	"maze": {
		"width": 15,
		"height": 15,
		"cell_size": 32,
		"max_fairness_delta": 30
	},
	"match": {
		"tick_interval": 0.5,
		"countdown_duration": 3.0,
		"max_match_duration": 300.0
	},
	"vision": {
		"vision_radius": 3,
